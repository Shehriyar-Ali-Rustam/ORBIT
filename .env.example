# Copy this to .env.local and fill in real values
# NEVER commit .env.local

# Gmail SMTP (contact & freelancer forms)
# Get app password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=hello.theorbit@gmail.com
EMAIL_PASS=your-gmail-app-password

# Anthropic Claude (chatbot — preferred provider) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini AI (chatbot fallback) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Override the preferred provider (anthropic | groq | gemini | openai). Defaults to anthropic.
AI_PROVIDER=anthropic

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
